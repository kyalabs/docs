          "how-it-works/overview",
          "how-it-works/panel-as-an-instrument",
          "how-it-works/two-lanes"
        ]
      },
      {
        "group": "Evidence & reliability",
        "icon": "shield-check",
        "pages": [
          "evidence/anatomy-of-a-run",
          "evidence/honesty-layer",
          "evidence/run-lifecycle-and-reliability"
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/panel-as-an-instrument",
      "destination": "/how-it-works/panel-as-an-instrument"
    },
    {
      "source": "/two-lanes",
      "destination": "/how-it-works/two-lanes"
    },
    {
      "source": "/anatomy-of-a-run",
      "destination": "/evidence/anatomy-of-a-run"
    },
    {
      "source": "/honesty-layer",
      "destination": "/evidence/honesty-layer"
    },
    {
      "source": "/run-lifecycle-and-reliability",
      "destination": "/evidence/run-lifecycle-and-reliability"
    }
  ]
}
