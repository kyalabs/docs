{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "kya labs",
  "colors": {
    "primary": "#2a9d8f",
    "light": "#2a9d8f",
    "dark": "#2a9d8f"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Hanken Grotesk",
    "heading": {
      "family": "Newsreader"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://kyalabs.com"
  },
  "favicon": "/favicon.png",
  "seo": {
    "metatags": {
      "robots": "noindex"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "icon": "sparkles",
        "pages": [
          "index"
        ]
      },
      {
